{
  "schemaVersion": 1,
  "id": "toms_mobs",
  "version": "${version}",
  "name": "Custom Remnants",
  "description": "Expanded mobs for The Remnants. Forked from tomalbrc/toms-mobs (MIT).",
  "icon": "icon@256.png",
  "authors": [
    "nickisashkir",
    "tomalbrc (original toms-mobs)"
  ],
  "contact": {
    "repo": "https://github.com/nickisashkir/expanded-toms-mobs"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "de.tomalbrc.toms_mobs.TomsMobs"
    ]
  },
  "mixins": [
    "toms_mobs.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": ">=26.1 <26.2",
    "fabric-api": "*",
    "polymer-resource-pack": "*",
    "polymer-core": "*",
    "polymer-virtual-entity": "*",
    "bil": ">=2.0.0-",
    "smartbrainlib": "*"
  },
  "accessWidener": "toms_mobs.accesswidener"
}
